# ─── Solana RPC ────────────────────────────────────────────────────────────────
# A premium RPC (Helius, Triton, QuickNode) is strongly recommended for any
# real order placement. Public endpoints rate-limit aggressively, especially
# during journal sync.
RPC_URL=https://api.mainnet-beta.solana.com
# BACKUP_RPC_1=
# BACKUP_RPC_2=

# Network: mainnet-beta or devnet
NETWORK=mainnet-beta

# ─── Wallet ────────────────────────────────────────────────────────────────────
# Path to a Solana CLI keypair JSON (64-byte secret-key array).
# Must live inside your $HOME. The terminal also auto-discovers wallets in:
#   - $WALLETS_DIR
#   - ~/.flash/wallets/
#   - ~/.config/solana/
# Switch at runtime with: wallet use <name>
WALLET_PATH=~/.config/solana/id.json
# WALLETS_DIR=

# Auto-disconnect wallet (zero keypair from memory) after this many ms idle.
# DEFAULT = 0 (disabled). Set to 900000 (15 min) if you want auto-lock.
# When disconnect fires (manual or timeout), any active maker/multi-maker auto-stops.
# SESSION_TIMEOUT_MS=0

# ─── Trading mode ──────────────────────────────────────────────────────────────
# true  = paper trading (no real transactions). Default.
# false = live trading. You must opt in explicitly.
# Also togglable at runtime via the `mode` command.
SIMULATION_MODE=true

# Master kill switch — set to false to block ALL on-chain order placement.
# TRADING_ENABLED=true

# ─── Compute budget ────────────────────────────────────────────────────────────
COMPUTE_UNIT_LIMIT=400000
COMPUTE_UNIT_PRICE=100000

# ─── Signing guards (USD or count) ─────────────────────────────────────────────
# Hard ceilings enforced before any order is signed. 0 = unlimited.
MAX_NOTIONAL_PER_ORDER=0
MAX_ORDERS_PER_MINUTE=20
# Was 500ms originally — 150ms allows the MM cancel + bid + ask sequence to run.
MIN_DELAY_BETWEEN_ORDERS_MS=150

# ─── AI translator (natural-language → command) ────────────────────────────────
# Defaults to Claude Haiku 4.5 (budget-friendly, ~1.5s steady-state).
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5

# ─── Jito bundles (optional, for MM landing reliability) ───────────────────────
# When set, `mm` and order commands can use --use-jito to send via Jito's block
# engine for guaranteed inclusion. Tip is added automatically.
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
# Default tip in lamports if --tip not specified. 0 = use 50th-percentile floor.
# JITO_DEFAULT_TIP_LAMPORTS=10000

# ─── Notifications (optional) ─────────────────────────────────────────────────
# Configure any subset — fills, MM start/stop, oracle divergence, errors push to all.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/.../.../...
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ALERT_WEBHOOK_URL=https://your-endpoint.example/alerts   # generic JSON POST
# ALERT_MIN_SEVERITY=info  # info | success | warning | error

# ─── Advisor AI (optional override) ────────────────────────────────────────────
# Defaults to AI_MODEL above. For deeper analysis, try Sonnet:
# ADVISOR_MODEL=claude-sonnet-4-6

# ─── Logging ───────────────────────────────────────────────────────────────────
# LOG_FILE=~/.phoenix/phoenix.log
# LOG_LEVEL=info
