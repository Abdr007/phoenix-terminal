{
  "name": "phoenix-terminal",
  "version": "0.1.0",
  "description": "On-chain trading terminal for the Phoenix CLOB on Solana — orderbook, limit/IOC orders, fills, and a basic market-maker loop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "phoenix": "dist/index.js",
    "phoenix-terminal": "dist/index.js",
    "pterm": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.js.map",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "phoenix",
    "ellipsis-labs",
    "solana",
    "clob",
    "orderbook",
    "market-maker",
    "trading",
    "terminal",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@ellipsis-labs/phoenix-sdk": "^2.0.3",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "bs58": "^5.0.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.6"
  }
}
